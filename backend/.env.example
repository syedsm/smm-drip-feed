# Backend Environment Variables Template
# Copy this to .env and fill in the values

# Server Configuration
PORT=5000
NODE_ENV=production

# Database (MongoDB Atlas recommended)
# IMPORTANT: Use a DB user with 'readWrite' permissions. 
# For Socket.io Change Streams, ensure you are using a Replica Set (MongoDB Atlas does this by default).
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/your_collection?retryWrites=true&w=majority

# Frontend URL (REQUIRED for Socket.io CORS)
# Local: http://localhost:5173
# Production: https://your-app-name.onrender.com
FRONTEND_URL=http://localhost:5173

# Server Configuration
PORT=5000
NODE_ENV=development
