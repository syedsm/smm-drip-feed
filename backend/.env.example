# Backend Environment Variables Template
# Copy this to .env and fill in the values

# Server Configuration
PORT=5000
NODE_ENV=production

# Database (MongoDB Atlas recommended)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/smm_drip_feed?retryWrites=true&w=majority

# Frontend URL (for CORS)
FRONTEND_URL=https://your-app-name.vercel.app

# Optional (for SMM Panel integration if globally set)
# PANEL_API_KEY=your_key_here
